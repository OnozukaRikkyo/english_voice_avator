      "Bash(gh --version)",
      "Bash(git --version)",
      "Bash(python3.12 --version)",
      "Bash(python3.11 --version)",
      "Bash(python3.10 --version)",
      "Bash(.venv/bin/pip install *)",
      "Bash(.venv/bin/pip freeze *)",
      "Bash(git init *)",
      "Bash(git config *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(gh auth *)",
      "Bash(gh repo *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(.venv/bin/python3 -c ' *)",

{
  "permissions": {
    "allow": [
      "Bash(pip3 --version)",
      "Bash(gh --version)",
      "Bash(git --version)",
      "Bash(python3.12 --version)",
      "Bash(python3.11 --version)",
      "Bash(python3.10 --version)",
      "Bash(.venv/bin/pip install *)",
      "Bash(.venv/bin/pip freeze *)",
      "Bash(git init *)",
      "Bash(git config *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(gh auth *)",
      "Bash(gh repo *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(.venv/bin/python3 -c ' *)",
      "Bash(.venv/bin/python3 run_pipeline.py --help)",
      "Bash(.venv/bin/python run_pipeline.py --steps convert)",
      "Bash(.venv/bin/python run_pipeline.py --steps transcribe)",
      "Bash(python3 -c ' *)",
      "Bash(.venv/bin/python run_pipeline.py --steps rewrite)",
      "Bash(.venv/bin/python3 -c \"from pipeline.rewrite import _build_prompt; print\\('OK'\\)\")",
      "Bash(.venv/bin/python tools/gen_spec.py)",
      "Bash(.venv/bin/python run_pipeline.py *)",
      "Bash(.venv/bin/python heygen_check.py *)",
      "Bash(.venv/bin/python tools/gen_notebooklm_prompt.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": \"## Pipeline design rules\\n- Entry point: python run_pipeline.py (no arguments needed for normal use)\\n- New audio files go in data/inbox/ — auto-scanned on every run\\n- MiniMax is FORBIDDEN: never add MiniMax code, imports, or references\\n- Project slug is always auto-derived from audio filename via slugify()\\n- Never rename existing files or directories\"}}'",
            "statusMessage": "Loading pipeline design rules..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport json, sys, re, os\ndata = json.load(sys.stdin)\npath = data.get('tool_input', {}).get('file_path', '')\nif path:\n    basename = os.path.basename(path)\n    if re.search(r'(?<![a-zA-Z])new(?![a-zA-Z])', basename, re.IGNORECASE):\n        print(json.dumps({'continue': False, 'stopReason': f'Filename contains \\\"new\\\": {basename}. Use a descriptive role-based name instead (e.g. video_guide.md not new_video.md).'}))\n\"",
            "statusMessage": "Checking filename convention..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/sonozuka/english_voice/avator && .venv/bin/python tools/gen_spec.py 2>/dev/null || true",
            "statusMessage": "Regenerating CLAUDE.md..."
          },
          {
            "type": "command",
            "command": "cd /home/sonozuka/english_voice/avator && .venv/bin/python tools/gen_docs.py 2>/dev/null || true",
            "statusMessage": "Regenerating docs/..."
          },
          {
            "type": "command",
            "command": "cd /home/sonozuka/english_voice/avator && .venv/bin/python tools/check_design.py",
            "statusMessage": "Checking data layout..."
          }
        ]
      }
    ]
  }
}
